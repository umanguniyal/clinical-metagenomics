#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cmd="${1:-}"
shift || true

case "${cmd}" in
  ingest)
    exec "${SCRIPT_DIR}/run_ingest.sh" "$@"
    ;;
  run)
    exec "${SCRIPT_DIR}/run_smk.sh" "$@"
    ;;
  *)
    echo "Usage:"
    echo "  ./pipeline ingest           # download/stage inputs + write manifests/samples.tsv"
    echo "  ./pipeline run [--cores N]  # run Snakemake using manifests/samples.tsv"
    echo ""
    echo "Optional:"
    echo "  ./pipeline run --interactive-manifest   # build manifests/samples.tsv on CLI then run"
    exit 1
    ;;
esac
